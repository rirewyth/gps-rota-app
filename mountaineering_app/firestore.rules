rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ADMIN KONTROL FONKSİYONU
    function isAdmin() {
      return request.auth != null && 
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.is_admin == true ||
         request.auth.token.email == 'sercanoral65@gmail.com' ||
         request.auth.token.email == 'admin@rota.plus');
    }

    // Kullanıcı profilleri
    match /users/{userId} {
      allow read: if true; // Web dashboard için herkese açık okuma izni
      allow write: if request.auth != null && request.auth.uid == userId;
      allow update: if request.auth != null;

      match /routes/{routeId} {
        allow read: if request.auth != null;
        allow write: if request.auth != null && request.auth.uid == userId;
      }

      match /{subcollection}/{docId} {
        allow read: if (request.auth != null && request.auth.uid == userId) || isAdmin();
        allow write: if request.auth != null && request.auth.uid == userId;
      }
    }

    // SOS Alarmları - Web komuta merkezi için herkese açık okuma
    match /sos_alerts/{docId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Koleksiyon Grubu İzni
    match /{path=**}/messages/{messageId} {
      allow read: if request.auth != null && (resource == null || isAdmin());
    }

    // Gönderiler
    match /posts/{postId} {
      allow read, create, update: if request.auth != null;
      allow delete: if request.auth != null &&
        (resource.data.userId == request.auth.uid ||
         request.auth.token.email == 'sercanoral65@gmail.com' || isAdmin());

      match /comments/{commentId} {
        allow read, write: if request.auth != null;
      }
    }

    // Mesajlaşma Odaları (DM)
    match /chats/{chatId} {
      allow read, write: if request.auth != null;
      match /messages/{messageId} {
        allow read, write: if request.auth != null;
      }
    }

    // Bildirimler
    match /notifications/{userId} {
      allow read: if (request.auth != null && request.auth.uid == userId) || isAdmin();
      allow write: if request.auth != null;
      match /items/{itemId} {
        allow read: if (request.auth != null && request.auth.uid == userId) || isAdmin();
        allow write, create: if request.auth != null;
      }
    }

    // Ekip odaları
    match /teams/{teamId} {
      allow read, write: if request.auth != null;
      match /messages/{msgId} { allow read, write: if request.auth != null; }
      match /members/{memberId} { allow read, write: if request.auth != null; }
    }

    match /announcements/{announcementId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null &&
        (request.auth.token.email == 'sercanoral65@gmail.com' || isAdmin());
    }

    // Rehber Başvuruları
    match /guide_applications/{docId} {
      allow read, write: if request.auth != null && (request.auth.uid == docId || isAdmin());
    }

    // Şikayetler (Reports)
    match /reports/{reportId} {
      allow create: if request.auth != null;
      allow read, update, delete: if isAdmin();
    }
  }
}
