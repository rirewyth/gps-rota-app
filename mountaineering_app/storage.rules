rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // Kullanıcı profil resimleri - sadece kendi klasörüne yazabilir
    match /users/{userId}/{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // Gönderi resimleri - giriş yapan herkes okuyabilir ve yazabilir
    match /posts/{fileName} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
                   && request.resource.size < 10 * 1024 * 1024 // Max 10MB
                   && request.resource.contentType.matches('image/.*');
    }

    // Ekip sesli mesajları (Walkie-Talkie)
    match /teams/{teamId}/voice/{fileName} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
                   && request.resource.size < 5 * 1024 * 1024; // Max 5MB ses
    }
  }
}
